package gui.real_estate_property_management_system;

import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.layout.VBox;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import javafx.scene.text.FontWeight;
import javafx.stage.*;

/**
 *
 * @author Shahzeb
 */
public class AgentDashBoardUI {
    public void show(Stage stage){
        Label agent = new Label("Agent DashBoard");
        agent.setFont(Font.font("Times New Roman",FontWeight.BOLD,35));      
        agent.setTextFill(Color.WHITE);
        
        Button assignedProperty=new Button("View Assigned Property");
        assignedProperty.setMaxWidth(220);
        assignedProperty.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        Button buyerRequest=new Button("Manage Buyer Request");
        buyerRequest.setMaxWidth(220);
        buyerRequest.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        Button scheduleVisit=new Button("Schedule Property Visit");
        scheduleVisit.setMaxWidth(220);
        scheduleVisit.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        Button generateAggrement=new Button("Generate Renatal aggrement");
        generateAggrement.setMaxWidth(220);
        generateAggrement.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        Button calculateCommision=new Button("Calculate Commision");
        calculateCommision.setMaxWidth(220);
        calculateCommision.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        Button logout=new Button("Logout");
        logout.setMaxWidth(220);
        logout.setStyle("-fx-background-radius: 100;"+"-fx-border-color: black;"+"-fx-border-radius: 100;");
        
        HBox topBox = new HBox();
        topBox.getChildren().addAll(agent);
        topBox.setStyle("-fx-background-color: #4682B4");
        topBox.setAlignment(Pos.CENTER);
        topBox.setPadding(new Insets(15));
        
        VBox formBox = new VBox(20);
        formBox.getChildren().addAll(assignedProperty,buyerRequest,scheduleVisit,generateAggrement,calculateCommision,logout);
        formBox.setAlignment(Pos.TOP_CENTER);
        formBox.setPadding(new Insets(30,0,20,0));
        formBox.setMaxWidth(300);
        formBox.setMaxHeight(340);
        formBox.setStyle("-fx-background-color: white;" + "-fx-border-color: black;" + "-fx-border-width: 2;" + "-fx-border-radius: 20;" + "-fx-background-radius: 20;");
        
        BorderPane root = new BorderPane();
        root.setTop(topBox);
        root.setCenter(formBox);
        
        Scene scene=new Scene(root,900,500);
        stage.setScene(scene);
        stage.setTitle("Real Estate Management System");   
        stage.show();
        
        
    }
    
}

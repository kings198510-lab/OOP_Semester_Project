package gui.real_estate_property_management_system;

/**
 *
 * @author Shahzeb
 */
public class Apartment extends Property{
    private int floorNo;
    private double noOfRooms;
    
    public Apartment(String propertyId,String title,String location,double price,double area,boolean isAvailable,boolean rented,int floorNo,double noOfRooms){
        super(propertyId,title,location,price,area,isAvailable,rented);
        this.floorNo=floorNo;
        this.noOfRooms=noOfRooms;
    }
    
    public void setFloorNo(int floorNo){
        this.floorNo=floorNo;
    }
    public int getFloorNo(){
        return floorNo;
    }
    
    public void setNoOfRooms(double noOfRooms){
        this.noOfRooms=noOfRooms;
    }
    public double getNoOfRooms(){
        return noOfRooms;
    }
    
    public void update(int floorNo,double noOfRooms){
        this.floorNo=floorNo;
        this.noOfRooms=noOfRooms;
    }
}

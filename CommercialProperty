package gui.real_estate_property_management_system;

/**
 *
 * @author Shahzeb
 */
public class CommercialProperty extends Property{
    private String businessType;
    private boolean parkingSpace;

    public CommercialProperty(String propertyId,String title,String location,double price,double area,boolean isAvailable,boolean rented,String businessType,boolean parkingSpace){
        super(propertyId,title,location,price,area,isAvailable,rented);
        this.businessType=businessType;
        this.parkingSpace=parkingSpace;
    }
    
    public void setBusinessType(String businessType){
        this.businessType=businessType;
    }
    public String getBusinessType(){
        return businessType;
    }
    
    public void setParkingSpace(boolean parkingSpace){
        this.parkingSpace=parkingSpace;
    }
    public boolean getParkingSpace(){
        return parkingSpace;
    }
    
    public void update(String businessType,boolean parkingSpace){
        this.businessType=businessType;
        this.parkingSpace=parkingSpace;
    }
    
}

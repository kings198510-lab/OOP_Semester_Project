public class House extends Property{
    private int rooms;
    private int floors;
    private boolean garageStatus;
    private boolean basementStatus;

    public House(int rooms , int floors , boolean garageStatus , boolean basementStatus){
        this.rooms=rooms;
        this.floors=floors;
        this.garageStatus=garageStatus;
        this.basementStatus=basementStatus;
    }
    
    public void setRooms(int rooms){
        this.rooms=rooms;
    }
    public int getRooms(){
        return rooms;
    }
    
    public void setFloors(int floors){
        this.floors=floors;
    }
    public int getFloors(){
        return floors;
    }
    
    public void setGarageStatus(boolean garageStatus){
        this.garageStatus=garageStatus;
    }
    public boolean getGarageStatus(){
        return garageStatus;
    }
    
    public void setBasementStatus(boolean basementStatus){
        this.basementStatus=basementStatus;
    }
    public boolean getBasementStatus(){
        return basementStatus;
    }
    
    
}

import java.util.*;


public class LoginManager implements Authenticable {
    
    
    public User login(ArrayList<User> users,String name,String password){
        for(int i=0;i<users.size();i++){
            if(((users.get(i).getName()).equalsIgnoreCase(name))&&((users.get(i).getPassword()).equals(password))){
                return users.get(i);
            }
        }
        return null;
    }
    public void logout(){
        System.out.println("Logged Out.");
    }
}

